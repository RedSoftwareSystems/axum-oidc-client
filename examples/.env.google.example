# .env.google.example — Google OAuth2 configuration
#
# Google supports OIDC autodiscovery but does NOT support RP-Initiated Logout.
# Do NOT set OAUTH_END_SESSION_ENDPOINT for Google.
#
# Setup:
#   1. Go to https://console.cloud.google.com/
#   2. Create project → APIs & Services → Credentials
#   3. Create OAuth 2.0 Client ID (Web application)
#   4. Add Authorised redirect URI: http://localhost:8080/auth/callback
#   5. Copy the client ID and secret below
#
# Usage:
#   cp .env.google.example .env.local
#   # fill in OAUTH_CLIENT_ID, OAUTH_CLIENT_SECRET and PRIVATE_COOKIE_KEY
#   make -C www-server run

# ── OIDC autodiscovery ────────────────────────────────────────────────────────
# Recommended: let the server fetch endpoints automatically.
OAUTH_ISSUER=https://accounts.google.com

# ── Credentials ───────────────────────────────────────────────────────────────
OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
OAUTH_CLIENT_SECRET=your-google-client-secret

# ── Callback URI ──────────────────────────────────────────────────────────────
OAUTH_REDIRECT_URI=http://localhost:8080/auth/callback

# ── Session ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
PRIVATE_COOKIE_KEY=change-me-to-a-64-byte-random-string

# ── Scopes ────────────────────────────────────────────────────────────────────
OAUTH_SCOPES=openid,email,profile

# ── www-server ────────────────────────────────────────────────────────────────
SERVER_HOST=127.0.0.1
SERVER_PORT=8080
API_SERVER=http://127.0.0.1:8181

# ── api-server ────────────────────────────────────────────────────────────────
# SERVER_HOST=127.0.0.1
# SERVER_PORT=8181

# ── Optional ──────────────────────────────────────────────────────────────────
# CUSTOM_CA_CERT=/path/to/ca.pem
# OAUTH_BASE_PATH=/auth
# CODE_CHALLENGE_METHOD=S256
# POST_LOGOUT_REDIRECT_URI=http://localhost:8080
