# .env.redis.example — Redis session cache configuration
#
# Use with: make redis-up  (starts Redis + api-server + www-server via Docker)
# Or:       make -C www-server run-redis   (run locally with Redis-only cache)
#           make -C www-server run-l1-redis (run locally with Moka L1 + Redis L2)
#
# Cache feature flags:
#   cache-l2       Redis only
#   cache-l1-l2    Moka L1 + Redis L2 (default in docker-compose.redis.yml)

# ── OIDC autodiscovery ────────────────────────────────────────────────────────
# Set to your provider's issuer URL. Examples:
#   Google:   https://accounts.google.com
#   Keycloak: https://keycloak.example.com/realms/your-realm
#   Azure AD: https://login.microsoftonline.com/{tenant}/v2.0
OAUTH_ISSUER=https://accounts.google.com

# ── Credentials ───────────────────────────────────────────────────────────────
OAUTH_CLIENT_ID=your-client-id
OAUTH_CLIENT_SECRET=your-client-secret

# ── Callback URI ──────────────────────────────────────────────────────────────
OAUTH_REDIRECT_URI=http://localhost:8080/auth/callback

# ── Logout (optional — only for providers that support RP-Initiated Logout) ───
# OAUTH_END_SESSION_ENDPOINT=
# POST_LOGOUT_REDIRECT_URI=http://localhost:8080

# ── Session ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
PRIVATE_COOKIE_KEY=change-me-to-a-64-byte-random-string

# ── Scopes ────────────────────────────────────────────────────────────────────
OAUTH_SCOPES=openid,email,profile

# ── www-server ────────────────────────────────────────────────────────────────
SERVER_HOST=127.0.0.1
SERVER_PORT=8080
API_SERVER=http://127.0.0.1:8181

# ── api-server ────────────────────────────────────────────────────────────────
# SERVER_HOST=127.0.0.1
# SERVER_PORT=8181

# ── Redis cache ───────────────────────────────────────────────────────────────
# When running locally (make run-redis), point at localhost.
# When running via Docker Compose, the service name "redis" is used instead
# (set automatically by the compose file — no need to change here).
REDIS_URL=redis://127.0.0.1:6379/
CACHE_TTL=3600

# ── Moka L1 cache (cache-l1-l2 only) ─────────────────────────────────────────
L1_MAX_CAPACITY=10000
L1_TTL_SEC=3600
# L1_TIME_TO_IDLE_SEC=1800

# ── Docker Compose — Redis container ──────────────────────────────────────────
REDIS_PORT=6379
# REDIS_PASSWORD=
REDIS_MAXMEMORY=256mb

# ── Optional ──────────────────────────────────────────────────────────────────
# CUSTOM_CA_CERT=/path/to/ca.pem
# OAUTH_BASE_PATH=/auth
# CODE_CHALLENGE_METHOD=S256
