# .env.azure.example — Azure AD / Microsoft Identity Platform configuration
#
# Azure AD supports full OIDC including RP-Initiated Logout.
# OAUTH_ISSUER enables autodiscovery — endpoints are fetched automatically.
#
# Setup:
#   1. Azure Portal → Azure Active Directory → App registrations → New registration
#   2. Set Redirect URI (Web): http://localhost:8080/auth/callback
#   3. Authentication → Add logout URL: http://localhost:8080
#   4. Certificates & secrets → New client secret
#   5. Copy Application (client) ID and the secret value below
#
# Usage:
#   cp .env.azure.example .env.local
#   # fill in AZURE_TENANT, OAUTH_CLIENT_ID, OAUTH_CLIENT_SECRET
#   # and PRIVATE_COOKIE_KEY
#   make -C www-server run

# ── Azure AD coordinates ──────────────────────────────────────────────────────
# Use your tenant ID (UUID), "common", "organizations", or "consumers"
AZURE_TENANT=common

# ── OIDC autodiscovery ────────────────────────────────────────────────────────
# Endpoints (auth, token, logout, JWKS) are fetched from the discovery document.
OAUTH_ISSUER=https://login.microsoftonline.com/${AZURE_TENANT}/v2.0

# ── Credentials ───────────────────────────────────────────────────────────────
OAUTH_CLIENT_ID=your-application-client-id
OAUTH_CLIENT_SECRET=your-client-secret-value

# ── Callback URI ──────────────────────────────────────────────────────────────
OAUTH_REDIRECT_URI=http://localhost:8080/auth/callback

# ── Logout ────────────────────────────────────────────────────────────────────
# Discovered automatically from OAUTH_ISSUER — override only if needed.
# OAUTH_END_SESSION_ENDPOINT=https://login.microsoftonline.com/${AZURE_TENANT}/oauth2/v2.0/logout
POST_LOGOUT_REDIRECT_URI=http://localhost:8080

# ── Session ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
PRIVATE_COOKIE_KEY=change-me-to-a-64-byte-random-string

# ── Scopes ────────────────────────────────────────────────────────────────────
OAUTH_SCOPES=openid,email,profile

# ── www-server ────────────────────────────────────────────────────────────────
SERVER_HOST=127.0.0.1
SERVER_PORT=8080
API_SERVER=http://127.0.0.1:8181

# ── api-server ────────────────────────────────────────────────────────────────
# SERVER_HOST=127.0.0.1
# SERVER_PORT=8181

# ── Optional ──────────────────────────────────────────────────────────────────
# CUSTOM_CA_CERT=/path/to/ca.pem
# OAUTH_BASE_PATH=/auth
# CODE_CHALLENGE_METHOD=S256
