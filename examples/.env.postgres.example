# .env.postgres.example — PostgreSQL session cache configuration
#
# Use with: make pg-up  (starts PostgreSQL + api-server + www-server via Docker)
# Or:       make -C www-server run-pg      (run locally with PostgreSQL-only cache)
#           make -C www-server run-l1-pg   (run locally with Moka L1 + PostgreSQL L2)
#
# Cache feature flags:
#   cache-pg       PostgreSQL only
#   cache-l1-pg    Moka L1 + PostgreSQL L2 (default in docker-compose.postgres.yml)

# ── OIDC autodiscovery ────────────────────────────────────────────────────────
# Set to your provider's issuer URL. Examples:
#   Google:   https://accounts.google.com
#   Keycloak: https://keycloak.example.com/realms/your-realm
#   Azure AD: https://login.microsoftonline.com/{tenant}/v2.0
OAUTH_ISSUER=https://accounts.google.com

# ── Credentials ───────────────────────────────────────────────────────────────
OAUTH_CLIENT_ID=your-client-id
OAUTH_CLIENT_SECRET=your-client-secret

# ── Callback URI ──────────────────────────────────────────────────────────────
OAUTH_REDIRECT_URI=http://localhost:8080/auth/callback

# ── Logout (optional — only for providers that support RP-Initiated Logout) ───
# OAUTH_END_SESSION_ENDPOINT=
# POST_LOGOUT_REDIRECT_URI=http://localhost:8080

# ── Session ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
PRIVATE_COOKIE_KEY=change-me-to-a-64-byte-random-string

# ── Scopes ────────────────────────────────────────────────────────────────────
OAUTH_SCOPES=openid,email,profile

# ── www-server ────────────────────────────────────────────────────────────────
SERVER_HOST=127.0.0.1
SERVER_PORT=8080
API_SERVER=http://127.0.0.1:8181

# ── api-server ────────────────────────────────────────────────────────────────
# SERVER_HOST=127.0.0.1
# SERVER_PORT=8181

# ── PostgreSQL cache ──────────────────────────────────────────────────────────
# When running locally (make run-pg), point at localhost.
# When running via Docker Compose, the service name "postgres" is used instead
# (set automatically by the compose file — no need to change here).
PG_URL=postgresql://oidc_user:oidc_pass@localhost:5432/oidc_cache
PG_MAX_CONNECTIONS=20
PG_CLEANUP_INTERVAL_SEC=300

# ── Moka L1 cache (cache-l1-pg only) ─────────────────────────────────────────
L1_MAX_CAPACITY=10000
PG_L1_TTL_SEC=1800
# L1_TIME_TO_IDLE_SEC=900

# ── Docker Compose — PostgreSQL container ─────────────────────────────────────
POSTGRES_USER=oidc_user
POSTGRES_PASSWORD=oidc_pass
POSTGRES_DB=oidc_cache
POSTGRES_PORT=5432
VACUUM_SCHEDULE=0 0 * * *

# ── Optional ──────────────────────────────────────────────────────────────────
# CUSTOM_CA_CERT=/path/to/ca.pem
# OAUTH_BASE_PATH=/auth
# CODE_CHALLENGE_METHOD=S256
