# .env.keycloak.example — Keycloak OIDC configuration
#
# Keycloak supports full OIDC including RP-Initiated Logout.
# OAUTH_ISSUER enables autodiscovery — endpoints are fetched automatically.
# OAUTH_END_SESSION_ENDPOINT is also discovered automatically but can be
# overridden here if needed.
#
# Setup:
#   1. Keycloak Admin Console → Select your realm
#   2. Clients → Create client
#      - Client type: OpenID Connect
#      - Client ID: your-client-id
#      - Client authentication: ON (confidential)
#   3. Settings tab:
#      - Valid redirect URIs: http://localhost:8080/auth/callback
#      - Valid post logout redirect URIs: http://localhost:8080
#   4. Credentials tab: copy the client secret
#
# Usage:
#   cp .env.keycloak.example .env.local
#   # fill in KEYCLOAK_URL, KEYCLOAK_REALM, OAUTH_CLIENT_ID,
#   # OAUTH_CLIENT_SECRET and PRIVATE_COOKIE_KEY
#   make -C www-server run

# ── Keycloak coordinates ──────────────────────────────────────────────────────
KEYCLOAK_URL=https://keycloak.example.com
KEYCLOAK_REALM=your-realm

# ── OIDC autodiscovery ────────────────────────────────────────────────────────
# Endpoints (auth, token, logout, JWKS) are fetched from the discovery document.
OAUTH_ISSUER=${KEYCLOAK_URL}/realms/${KEYCLOAK_REALM}

# ── Credentials ───────────────────────────────────────────────────────────────
OAUTH_CLIENT_ID=your-client-id
OAUTH_CLIENT_SECRET=your-client-secret

# ── Callback URI ──────────────────────────────────────────────────────────────
OAUTH_REDIRECT_URI=http://localhost:8080/auth/callback

# ── Logout ────────────────────────────────────────────────────────────────────
# Discovered automatically from OAUTH_ISSUER — override only if needed.
# OAUTH_END_SESSION_ENDPOINT=${KEYCLOAK_URL}/realms/${KEYCLOAK_REALM}/protocol/openid-connect/logout
POST_LOGOUT_REDIRECT_URI=http://localhost:8080

# ── Session ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
PRIVATE_COOKIE_KEY=change-me-to-a-64-byte-random-string

# ── Scopes ────────────────────────────────────────────────────────────────────
OAUTH_SCOPES=openid,email,profile

# ── www-server ────────────────────────────────────────────────────────────────
SERVER_HOST=127.0.0.1
SERVER_PORT=8080
API_SERVER=http://127.0.0.1:8181

# ── api-server ────────────────────────────────────────────────────────────────
# SERVER_HOST=127.0.0.1
# SERVER_PORT=8181

# ── Optional ──────────────────────────────────────────────────────────────────
# CUSTOM_CA_CERT=/path/to/ca.pem   # needed if Keycloak uses a private CA
# OAUTH_BASE_PATH=/auth
# CODE_CHALLENGE_METHOD=S256
