# .env.sqlite.example — SQLite session cache configuration
#
# SQLite requires no external server — the cache database is a plain file.
#
# Use with: make sqlite-up  (starts SQLite sidecar + api-server + www-server via Docker)
# Or:       make -C www-server run-sqlite      (run locally, file at /tmp/oidc_cache.db)
#           make -C www-server run-l1-sqlite   (run locally with Moka L1 + SQLite L2)
#
# Cache feature flags:
#   cache-sqlite       SQLite only
#   cache-l1-sqlite    Moka L1 + SQLite L2 (default in docker-compose.sqlite.yml)
#
# SQLite URL formats:
#   sqlite:///tmp/oidc_cache.db       file at /tmp/oidc_cache.db  (local dev)
#   sqlite:////data/oidc_cache.db     absolute path (four slashes) — Docker volume
#   sqlite://:memory:                 in-memory only (lost on restart — testing only)

# ── OIDC autodiscovery ────────────────────────────────────────────────────────
# Set to your provider's issuer URL. Examples:
#   Google:   https://accounts.google.com
#   Keycloak: https://keycloak.example.com/realms/your-realm
#   Azure AD: https://login.microsoftonline.com/{tenant}/v2.0
OAUTH_ISSUER=https://accounts.google.com

# ── Credentials ───────────────────────────────────────────────────────────────
OAUTH_CLIENT_ID=your-client-id
OAUTH_CLIENT_SECRET=your-client-secret

# ── Callback URI ──────────────────────────────────────────────────────────────
OAUTH_REDIRECT_URI=http://localhost:8080/auth/callback

# ── Logout (optional — only for providers that support RP-Initiated Logout) ───
# OAUTH_END_SESSION_ENDPOINT=
# POST_LOGOUT_REDIRECT_URI=http://localhost:8080

# ── Session ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
PRIVATE_COOKIE_KEY=change-me-to-a-64-byte-random-string

# ── Scopes ────────────────────────────────────────────────────────────────────
OAUTH_SCOPES=openid,email,profile

# ── www-server ────────────────────────────────────────────────────────────────
SERVER_HOST=127.0.0.1
SERVER_PORT=8080
API_SERVER=http://127.0.0.1:8181

# ── api-server ────────────────────────────────────────────────────────────────
# SERVER_HOST=127.0.0.1
# SERVER_PORT=8181

# ── SQLite cache ──────────────────────────────────────────────────────────────
# Local development: use /tmp
SQLITE_URL=sqlite:///tmp/oidc_cache.db
# Docker volume (after make sqlite-up):
# SQLITE_URL=sqlite:////data/oidc_cache.db
SQLITE_MAX_CONNECTIONS=5
SQLITE_CLEANUP_INTERVAL_SEC=300

# ── Moka L1 cache (cache-l1-sqlite only) ─────────────────────────────────────
L1_MAX_CAPACITY=10000
SQLITE_L1_TTL_SEC=1800
# L1_TIME_TO_IDLE_SEC=900

# ── Docker Compose — SQLite sidecar ──────────────────────────────────────────
SQLITE_DB_PATH=/data/oidc_cache.db
VACUUM_SCHEDULE=0 0 * * *

# ── Optional ──────────────────────────────────────────────────────────────────
# CUSTOM_CA_CERT=/path/to/ca.pem
# OAUTH_BASE_PATH=/auth
# CODE_CHALLENGE_METHOD=S256
