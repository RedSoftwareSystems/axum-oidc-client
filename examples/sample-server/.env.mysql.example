# .env.mysql.example
# ──────────────────────────────────────────────────────────────────────────────
# Example environment file for running the sample-server with a MySQL /
# MariaDB cache backend (cache-mysql or cache-l1-mysql feature).
#
# Quick start
# ───────────
#   1. Copy this file:
#        cp .env.mysql.example .env.local
#
#   2. Fill in your real OAuth2 credentials below.
#
#   3. Start MySQL via Docker Compose:
#        docker compose -f docker/docker-compose.mysql.yml up -d
#
#   4. Run the server with the two-tier (Moka L1 + MySQL L2) cache:
#        cargo run --no-default-features --features cache-l1-mysql
#
#      Or MySQL-only (no in-process L1 layer):
#        cargo run --no-default-features --features cache-mysql
#
# ──────────────────────────────────────────────────────────────────────────────

# ── OAuth2 / OIDC ─────────────────────────────────────────────────────────────

# Authorization endpoint of your OAuth2 / OIDC provider.
# Examples:
#   Google:   https://accounts.google.com/o/oauth2/auth
#   Keycloak: https://your-keycloak.example.com/realms/myrealm/protocol/openid-connect/auth
OAUTH_AUTHORIZATION_ENDPOINT=https://accounts.google.com/o/oauth2/auth

# Token endpoint of your OAuth2 / OIDC provider.
# Examples:
#   Google:   https://oauth2.googleapis.com/token
#   Keycloak: https://your-keycloak.example.com/realms/myrealm/protocol/openid-connect/token
OAUTH_TOKEN_ENDPOINT=https://oauth2.googleapis.com/token

# (Optional) OIDC RP-Initiated Logout endpoint.
# Set ONLY for providers that support OIDC logout (Keycloak, Azure AD, Okta, Auth0).
# Leave commented out for Google or GitHub — they do NOT support OIDC logout.
#
# Keycloak example:
#   OAUTH_END_SESSION_ENDPOINT=https://your-keycloak.example.com/realms/myrealm/protocol/openid-connect/logout
#
# Azure AD example:
#   OAUTH_END_SESSION_ENDPOINT=https://login.microsoftonline.com/<tenant>/oauth2/v2.0/logout
#OAUTH_END_SESSION_ENDPOINT=

# (Optional) Where to redirect users after a successful logout.
# Defaults to "/" if not set.
#POST_LOGOUT_REDIRECT_URI=http://localhost:8080/home

# Your OAuth2 client ID (required).
OAUTH_CLIENT_ID=your-client-id-here

# Your OAuth2 client secret (required).
OAUTH_CLIENT_SECRET=your-client-secret-here

# The URI your OAuth2 provider will redirect back to after authentication.
# Must match EXACTLY what is registered in your OAuth2 provider console.
OAUTH_REDIRECT_URI=http://localhost:8080/auth/callback

# OAuth2 scopes to request (comma-separated, no spaces).
# Google / Keycloak / Azure: openid,email,profile
# GitHub:                    read:user,user:email
OAUTH_SCOPES=openid,email,profile

# ── Server ────────────────────────────────────────────────────────────────────

SERVER_HOST=127.0.0.1
SERVER_PORT=8080

# Base path under which the auth routes are mounted (default: /auth).
# The callback URL must be: <OAUTH_REDIRECT_URI> = <scheme>://<host>:<port><OAUTH_BASE_PATH>/callback
OAUTH_BASE_PATH=/auth

# ── Security ──────────────────────────────────────────────────────────────────

# Secret key used to encrypt session cookies.
# Generate a secure random value with:
#   openssl rand -base64 64
# NEVER use the placeholder below in production!
PRIVATE_COOKIE_KEY=change-this-to-a-secure-random-64-byte-base64-encoded-string

# PKCE code challenge method: S256 (recommended) or plain.
CODE_CHALLENGE_METHOD=S256

# (Optional) Path to a custom CA certificate (PEM format).
# Required when your OAuth2 provider uses a self-signed or private CA cert.
#CUSTOM_CA_CERT=/etc/ssl/certs/my-private-ca.pem

# ── MySQL / MariaDB cache (cache-mysql / cache-l1-mysql) ──────────────────────
#
# These variables are only read when the binary is compiled with:
#   --features cache-mysql      (MySQL-only, no in-process L1 layer)
#   --features cache-l1-mysql   (Moka L1 in front of MySQL L2 — recommended)
#
# The Docker Compose stack in docker/docker-compose.mysql.yml starts a MySQL 8
# container with the default credentials below.  Change both here and in the
# compose environment / .env file if you use different credentials.

# MySQL / MariaDB connection URL.
# Format: mysql://<user>:<password>@<host>:<port>/<database>
#
# Matches the defaults in docker/docker-compose.mysql.yml:
MYSQL_URL=mysql://oidc_user:oidc_pass@localhost:3306/oidc_cache

# Maximum number of connections in the application-side connection pool.
# Keep this below MySQL's max_connections (200 in the compose stack).
# For a single-instance sample server 20 is more than sufficient.
MYSQL_MAX_CONNECTIONS=20

# How often (seconds) the background cleanup task sweeps the oidc_cache table
# for expired rows.  Combined with the nightly OPTIMIZE + ANALYZE job run by
# the docker/optimize-cron service, this keeps the table lean.
# Default: 300 (5 minutes)
MYSQL_CLEANUP_INTERVAL_SEC=300

# ── Moka L1 cache (cache-l1 / cache-l1-l2 / cache-l1-mysql) ─────────────────
#
# These variables are only read when the binary is compiled with a feature that
# includes the Moka in-process L1 layer (cache-l1, cache-l1-l2, cache-l1-mysql).

# Maximum number of entries held in the Moka in-process cache.
# When the limit is reached, least-recently-used entries are evicted.
L1_MAX_CAPACITY=10000

# Time-to-live for Moka L1 entries when used WITHOUT a MySQL L2 backend.
# (Applies to cache-l1 and cache-l1-l2 only.)
L1_TTL_SEC=3600

# (Optional) Time-to-idle for Moka L1 entries when used WITHOUT MySQL.
# Entries not accessed within this window are evicted even if their TTL has not
# expired.  Leave commented out to disable idle-based eviction.
#L1_TIME_TO_IDLE_SEC=1800

# TTL (seconds) for the Moka L1 layer when used IN FRONT OF MySQL.
# (Applies to cache-l1-mysql only.)
# Should be <= the session max-age so that an L1 hit never returns a session
# that has already been invalidated in MySQL.
# Default: 1800 (30 minutes — half the 1-hour session TTL is a safe choice)
MYSQL_L1_TTL_SEC=1800

# ── Docker Compose MySQL settings ─────────────────────────────────────────────
#
# The variables below are consumed by docker/docker-compose.mysql.yml, NOT by
# the Rust application.  They control the MySQL container itself.
# Keep MYSQL_USER / MYSQL_PASSWORD / MYSQL_DATABASE in sync with MYSQL_URL above.

# MySQL application user.  The official MySQL image creates this user
# automatically and grants it all privileges on MYSQL_DATABASE.
MYSQL_USER=oidc_user
MYSQL_PASSWORD=oidc_pass

# Database / schema name.
MYSQL_DATABASE=oidc_cache

# MySQL root password (required by the official MySQL Docker image even when
# using MYSQL_USER / MYSQL_PASSWORD for the application user).
# Change this in any environment where the container is reachable from outside
# localhost.
MYSQL_ROOT_PASSWORD=root_pass

# Host-side port the MySQL container listens on.
# Change if port 3306 is already in use on your machine.
MYSQL_PORT=3306

# Cron schedule for the nightly OPTIMIZE TABLE + ANALYZE TABLE job
# (5-field cron expression).
# Default: every day at midnight UTC ("0 0 * * *").
# Override to test more frequently, e.g. every 5 minutes: "*/5 * * * *"
OPTIMIZE_SCHEDULE=0 0 * * *
