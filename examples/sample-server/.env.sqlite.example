# .env.sqlite.example
# ──────────────────────────────────────────────────────────────────────────────
# Example environment configuration for the axum-oidc-client sample-server
# using the SQLite cache backend (cache-sqlite or cache-l1-sqlite).
#
# Usage
# ─────
#   cp .env.sqlite.example .env.local
#   # Edit .env.local — fill in real OAuth2 credentials.
#   # Optionally adjust SQLITE_URL to point to a custom file path.
#
#   # SQLite-only cache (no Moka L1 layer):
#   make run-sqlite
#   # or:
#   cargo run --no-default-features --features cache-sqlite
#
#   # Two-tier: Moka L1 in front of SQLite L2 (recommended):
#   make run-l1-sqlite
#   # or:
#   cargo run --no-default-features --features cache-l1-sqlite
#
# SQLite URL formats
# ──────────────────
#   sqlite:///path/to/cache.db   — relative or absolute file path
#                                  (three slashes = relative, four = absolute)
#   sqlite:////data/oidc_cache.db — absolute path inside a Docker volume
#                                   (use with `make sqlite-up`)
#   sqlite://:memory:            — in-process only, lost on restart (testing)
#
# No database server setup is required — SQLite creates the file automatically
# on first connection if the parent directory exists and is writable.
# ──────────────────────────────────────────────────────────────────────────────

# ── OAuth2 / OIDC ─────────────────────────────────────────────────────────────
# Replace with your actual provider credentials.
OAUTH_AUTHORIZATION_ENDPOINT=https://accounts.google.com/o/oauth2/auth
OAUTH_TOKEN_ENDPOINT=https://oauth2.googleapis.com/token
# OAUTH_END_SESSION_ENDPOINT=   # only for OIDC-compliant providers (Keycloak, Azure AD, etc.)
# POST_LOGOUT_REDIRECT_URI=http://localhost:8080

OAUTH_CLIENT_ID=your-client-id-here
OAUTH_CLIENT_SECRET=your-client-secret-here
OAUTH_REDIRECT_URI=http://localhost:8080/auth/callback
OAUTH_SCOPES=openid,email,profile

# Generate with: openssl rand -base64 64
PRIVATE_COOKIE_KEY=change-this-to-a-secure-random-string-at-least-64-chars

CODE_CHALLENGE_METHOD=S256
OAUTH_BASE_PATH=/auth

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_HOST=127.0.0.1
SERVER_PORT=8080

# ── SQLite cache ──────────────────────────────────────────────────────────────
# File path for the SQLite database.
# Use the Docker volume path when running with `make sqlite-up`:
#   SQLITE_URL=sqlite:////data/oidc_cache.db
# Use a local path for development without Docker:
#   SQLITE_URL=sqlite:///tmp/oidc_cache.db
SQLITE_URL=sqlite:///tmp/oidc_cache.db

# Maximum number of connections in the SQLite pool.
# Keep this low (1–5) — SQLite supports only one concurrent writer.
SQLITE_MAX_CONNECTIONS=5

# How often (seconds) the background task sweeps expired rows.
SQLITE_CLEANUP_INTERVAL_SEC=300

# ── Moka L1 cache (cache-l1-sqlite only) ─────────────────────────────────────
# These settings only take effect when the cache-l1-sqlite feature is active.
L1_MAX_CAPACITY=10000
SQLITE_L1_TTL_SEC=1800
# L1_TIME_TO_IDLE_SEC=900   # optional: evict idle L1 entries after 15 min
