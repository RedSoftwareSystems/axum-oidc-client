# .env.github.example — GitHub OAuth2 configuration
#
# GitHub uses OAuth2 only — it is NOT a full OIDC provider.
# - No OAUTH_ISSUER (no discovery document)
# - No id_token (only access_token is returned)
# - No OAUTH_END_SESSION_ENDPOINT
# - Scopes use GitHub's own format, not OIDC scopes
#
# Setup:
#   1. Go to https://github.com/settings/developers
#   2. New OAuth App
#   3. Set Homepage URL: http://localhost:8080
#   4. Set Authorization callback URL: http://localhost:8080/auth/callback
#   5. Copy the client ID and secret below
#
# Usage:
#   cp .env.github.example .env.local
#   # fill in OAUTH_CLIENT_ID, OAUTH_CLIENT_SECRET and PRIVATE_COOKIE_KEY
#   make -C www-server run

# ── Endpoints (manual — GitHub has no OIDC discovery) ────────────────────────
OAUTH_AUTHORIZATION_ENDPOINT=https://github.com/login/oauth/authorize
OAUTH_TOKEN_ENDPOINT=https://github.com/login/oauth/access_token

# ── Credentials ───────────────────────────────────────────────────────────────
OAUTH_CLIENT_ID=your-github-client-id
OAUTH_CLIENT_SECRET=your-github-client-secret

# ── Callback URI ──────────────────────────────────────────────────────────────
OAUTH_REDIRECT_URI=http://localhost:8080/auth/callback

# ── Session ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
PRIVATE_COOKIE_KEY=change-me-to-a-64-byte-random-string

# ── Scopes (GitHub format — NOT OIDC scopes) ──────────────────────────────────
OAUTH_SCOPES=read:user,user:email

# ── www-server ────────────────────────────────────────────────────────────────
SERVER_HOST=127.0.0.1
SERVER_PORT=8080
API_SERVER=http://127.0.0.1:8181

# ── api-server ────────────────────────────────────────────────────────────────
# SERVER_HOST=127.0.0.1
# SERVER_PORT=8181

# ── Optional ──────────────────────────────────────────────────────────────────
# CUSTOM_CA_CERT=/path/to/ca.pem
# OAUTH_BASE_PATH=/auth
# CODE_CHALLENGE_METHOD=S256
