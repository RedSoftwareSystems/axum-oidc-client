# .env.mysql.example — MySQL / MariaDB session cache configuration
#
# Use with: make mysql-up  (starts MySQL + api-server + www-server via Docker)
# Or:       make -C www-server run-mysql      (run locally with MySQL-only cache)
#           make -C www-server run-l1-mysql   (run locally with Moka L1 + MySQL L2)
#
# Cache feature flags:
#   cache-mysql       MySQL only
#   cache-l1-mysql    Moka L1 + MySQL L2 (default in docker-compose.mysql.yml)

# ── OIDC autodiscovery ────────────────────────────────────────────────────────
# Set to your provider's issuer URL. Examples:
#   Google:   https://accounts.google.com
#   Keycloak: https://keycloak.example.com/realms/your-realm
#   Azure AD: https://login.microsoftonline.com/{tenant}/v2.0
OAUTH_ISSUER=https://accounts.google.com

# ── Credentials ───────────────────────────────────────────────────────────────
OAUTH_CLIENT_ID=your-client-id
OAUTH_CLIENT_SECRET=your-client-secret

# ── Callback URI ──────────────────────────────────────────────────────────────
OAUTH_REDIRECT_URI=http://localhost:8080/auth/callback

# ── Logout (optional — only for providers that support RP-Initiated Logout) ───
# OAUTH_END_SESSION_ENDPOINT=
# POST_LOGOUT_REDIRECT_URI=http://localhost:8080

# ── Session ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
PRIVATE_COOKIE_KEY=change-me-to-a-64-byte-random-string

# ── Scopes ────────────────────────────────────────────────────────────────────
OAUTH_SCOPES=openid,email,profile

# ── www-server ────────────────────────────────────────────────────────────────
SERVER_HOST=127.0.0.1
SERVER_PORT=8080
API_SERVER=http://127.0.0.1:8181

# ── api-server ────────────────────────────────────────────────────────────────
# SERVER_HOST=127.0.0.1
# SERVER_PORT=8181

# ── MySQL / MariaDB cache ─────────────────────────────────────────────────────
# When running locally (make run-mysql), point at localhost.
# When running via Docker Compose, the service name "mysql" is used instead
# (set automatically by the compose file — no need to change here).
MYSQL_URL=mysql://oidc_user:oidc_pass@localhost:3306/oidc_cache
MYSQL_MAX_CONNECTIONS=20
MYSQL_CLEANUP_INTERVAL_SEC=300

# ── Moka L1 cache (cache-l1-mysql only) ──────────────────────────────────────
L1_MAX_CAPACITY=10000
MYSQL_L1_TTL_SEC=1800
# L1_TIME_TO_IDLE_SEC=900

# ── Docker Compose — MySQL container ─────────────────────────────────────────
MYSQL_USER=oidc_user
MYSQL_PASSWORD=oidc_pass
MYSQL_DATABASE=oidc_cache
MYSQL_ROOT_PASSWORD=root_pass
MYSQL_PORT=3306
OPTIMIZE_SCHEDULE=0 0 * * *

# ── Optional ──────────────────────────────────────────────────────────────────
# CUSTOM_CA_CERT=/path/to/ca.pem
# OAUTH_BASE_PATH=/auth
# CODE_CHALLENGE_METHOD=S256
